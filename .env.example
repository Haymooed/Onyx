# ─────────────────────────────────────────────────
#   RPcustom — .env.example
#   Copy this file to .env and fill in your values
#   DO NOT commit .env to git
# ─────────────────────────────────────────────────

# Your Discord account token — auto-saved to config.yml on first start
DISCORD_TOKEN=PASTE_YOUR_DISCORD_TOKEN_HERE

# Panel login password (default: admin)
PANEL_PASS=admin

# Port (Wispbyte/Pterodactyl sets this automatically via SERVER_PORT)
SERVER_PORT=3000
