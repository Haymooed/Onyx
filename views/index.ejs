<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Onyx Panel — Pink Edition</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root {
  --bg: #0f0b12;
  --surface: #1a1420;
  --surface2: #241c2c;
  --surface3: #2d2436;
  --border: rgba(255, 105, 180, 0.15);
  --border-hover: rgba(255, 105, 180, 0.3);
  --accent: #ff69b4; /* Hot Pink */
  --accent2: #ff1493; /* Deep Pink */
  --accent-glow: rgba(255, 105, 180, 0.3);
  --text: #f8e8f0;
  --text-dim: #b09eb0;
  --text-muted: #6e5e6e;
  --green: #00d97e;
  --red: #ff4d4d;
  --yellow: #ffaa00;
  --sidebar-width: 240px;
}

* { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Space Grotesk', sans-serif; }

body {
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
  background-image: radial-gradient(ellipse at 0% 0%, rgba(255, 105, 180, 0.08) 0%, transparent 40%),
                   radial-gradient(ellipse at 100% 100%, rgba(255, 20, 147, 0.05) 0%, transparent 40%);
}

/* Sidebar */
.sidebar {
  width: var(--sidebar-width);
  background: var(--surface);
  border-right: 1px solid var(--border);
  height: 100vh;
  position: fixed;
  left: 0;
  top: 0;
  display: flex;
  flex-direction: column;
  z-index: 100;
}

.sidebar-header {
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid var(--border);
}

.brand-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, var(--accent2), var(--accent));
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 16px var(--accent-glow);
}

.brand-icon svg { width: 18px; height: 18px; fill: #fff; }

.brand-name {
  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: -.02em;
  background: linear-gradient(90deg, #fff, var(--accent));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.nav-links {
  padding: 16px;
  flex: 1;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  color: var(--text-dim);
  text-decoration: none;
  border-radius: 10px;
  margin-bottom: 4px;
  transition: .2s;
  cursor: pointer;
  border: 1px solid transparent;
}

.nav-item i { width: 18px; text-align: center; }

.nav-item:hover {
  background: rgba(255, 105, 180, 0.05);
  color: var(--text);
}

.nav-item.active {
  background: rgba(255, 105, 180, 0.1);
  color: var(--accent);
  border-color: var(--border);
}

.sidebar-footer {
  padding: 16px;
  border-top: 1px solid var(--border);
}

/* Main Content */
.main-content {
  margin-left: var(--sidebar-width);
  flex: 1;
  padding: 32px;
  max-width: calc(100vw - var(--sidebar-width));
}

.section { display: none; animation: fadeIn 0.3s ease; }
.section.active { display: block; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.header h2 { font-size: 1.5rem; font-weight: 700; }

.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px; }
@media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

/* Cards & Components */
.card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 24px; height: 100%; }
.card-title {
  font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em;
  color: var(--accent); margin-bottom: 20px; display: flex; align-items: center; gap: 8px;
}

.field { margin-bottom: 16px; }
.field label { display: block; font-size: .7rem; color: var(--text-dim); font-weight: 700; text-transform: uppercase; letter-spacing: .07em; margin-bottom: 8px; }

input[type=text], input[type=password], input[type=url], input[type=number], input[type=datetime-local], select, textarea {
  width: 100%; padding: 10px 14px; background: var(--surface2); border: 1px solid var(--border);
  border-radius: 10px; color: var(--text); font-size: .9rem; outline: none; transition: .2s; font-family: inherit;
}

input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(255, 105, 180, 0.1); }

.btn {
  padding: 10px 20px; border: none; border-radius: 10px; font-size: .85rem; font-weight: 700; cursor: pointer;
  transition: .2s; font-family: inherit; display: inline-flex; align-items: center; gap: 8px;
}

.btn-primary { background: linear-gradient(90deg, var(--accent2), var(--accent)); color: #fff; box-shadow: 0 4px 15px var(--accent-glow); }
.btn-primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(255, 105, 180, 0.4); }
.btn-ghost { background: rgba(255, 105, 180, 0.08); border: 1px solid var(--border); color: var(--accent); }
.btn-ghost:hover { background: rgba(255, 105, 180, 0.15); }
.btn-danger { background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); color: var(--red); }
.btn-danger:hover { background: rgba(255, 77, 77, 0.2); }

/* Presence Preview */
.preview { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 16px; display: flex; gap: 16px; align-items: flex-start; margin-top: 16px; }
.prev-img { width: 64px; height: 64px; border-radius: 10px; background: var(--surface3); flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 1.5rem; overflow: hidden; }
.prev-img img { width: 100%; height: 100%; object-fit: cover; }
.prev-type { font-size: .65rem; font-weight: 700; text-transform: uppercase; color: var(--text-dim); margin-bottom: 4px; }
.prev-name { font-size: 1rem; font-weight: 700; color: #fff; }
.prev-details, .prev-state { font-size: .85rem; color: var(--text-dim); margin-top: 2px; }

/* Connection Status */
.status-card { display: flex; align-items: center; gap: 16px; padding: 12px 20px; background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 24px; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot-g { background: var(--green); box-shadow: 0 0 10px var(--green); }
.dot-y { background: var(--yellow); box-shadow: 0 0 10px var(--yellow); }
.dot-r { background: var(--red); box-shadow: 0 0 10px var(--red); }
.status-info { flex: 1; }
.status-tag { font-weight: 700; font-size: 0.9rem; }
.status-sub { font-size: 0.75rem; color: var(--text-dim); }

/* Toggles */
.toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
.toggle-row:last-child { border-bottom: none; }
.switch { position: relative; display: inline-block; width: 44px; height: 24px; }
.switch input { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--surface3); transition: .4s; border-radius: 24px; border: 1px solid var(--border); }
.slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: var(--text-muted); transition: .4s; border-radius: 50%; }
input:checked + .slider { background-color: var(--accent2); border-color: var(--accent); }
input:checked + .slider:before { transform: translateX(20px); background-color: white; }

/* Lists */
.row-list { display: grid; gap: 10px; margin-top: 10px; }
.row-item { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 14px; display: flex; justify-content: space-between; align-items: center; }
.ri-main { flex: 1; }
.tag { background: rgba(255, 105, 180, 0.15); color: var(--accent); padding: 2px 8px; border-radius: 99px; font-size: .65rem; font-weight: 700; margin-right: 6px; }

/* Quests */
.quest-item { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 14px; display: flex; align-items: center; gap: 16px; margin-bottom: 10px; }
.quest-icon { width: 48px; height: 48px; border-radius: 10px; background: var(--surface3); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.quest-icon img { width: 100%; height: 100%; object-fit: cover; }
.quest-info { flex: 1; }
.quest-log { background: #0a080d; border: 1px solid var(--border); border-radius: 12px; padding: 16px; height: 300px; overflow-y: auto; font-family: monospace; font-size: .8rem; color: #d0c0d0; line-height: 1.6; }

/* Toast & Save Bar */
.save-bar { position: fixed; bottom: 24px; right: 24px; padding: 16px 24px; background: var(--surface); border: 1px solid var(--accent); border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); display: flex; align-items: center; gap: 20px; z-index: 200; transform: translateY(100px); transition: .3s; }
.save-bar.active { transform: translateY(0); }
.toast { position: fixed; top: 24px; right: 24px; padding: 12px 24px; border-radius: 12px; font-weight: 600; z-index: 300; animation: slideIn 0.3s ease; }
.tok { background: #1a2a1a; border: 1px solid var(--green); color: var(--green); }
.terr { background: #2a1a1a; border: 1px solid var(--red); color: var(--red); }
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* Mobile */
@media (max-width: 768px) {
  .sidebar { width: 60px; }
  .brand-name, .nav-item span { display: none; }
  .main-content { margin-left: 60px; padding: 20px; max-width: calc(100vw - 60px); }
  .nav-item { padding: 12px; justify-content: center; }
}
</style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-header">
    <div class="brand-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71L12 2z"/></svg>
    </div>
    <span class="brand-name">Onyx Panel</span>
  </div>
  <div class="nav-links">
    <div class="nav-item active" onclick="showSection('presence')"><i class="fas fa-id-card"></i> <span>Presence</span></div>
    <div class="nav-item" onclick="showSection('quests')"><i class="fas fa-khanda"></i> <span>Quests</span></div>
    <div class="nav-item" onclick="showSection('automation')"><i class="fas fa-robot"></i> <span>Automation</span></div>
    <div class="nav-item" onclick="showSection('messages')"><i class="fas fa-paper-plane"></i> <span>Messages</span></div>
    <div class="nav-item" onclick="showSection('utility')"><i class="fas fa-tools"></i> <span>Utility</span></div>
  </div>
  <div class="sidebar-footer">
    <a href="/login" class="nav-item" style="color: var(--red)"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></a>
  </div>
</div>

<div class="main-content">
  <!-- Status Card -->
  <div class="status-card">
    <div id="statusDot" class="dot dot-gray"></div>
    <div class="status-info">
      <div id="statusTag" class="status-tag">Checking...</div>
      <div id="statusSub" class="status-sub">Attempting to connect to backend</div>
    </div>
    <button id="connectBtn" class="btn btn-primary" onclick="toggleConnect()"><i class="fas fa-plug"></i> Connect</button>
  </div>

  <!-- Presence Section -->
  <div id="presence" class="section active">
    <div class="header"><h2>Presence & RPC</h2></div>
    <div class="grid">
      <div class="card">
        <div class="card-title"><i class="fas fa-cog"></i> General Settings</div>
        <div class="field">
          <label>Discord Token</label>
          <div style="display:flex; gap:8px">
            <input type="password" id="token" placeholder="mfa.xxxx...">
            <button class="btn btn-ghost" onclick="saveToken()"><i class="fas fa-save"></i></button>
          </div>
        </div>
        <div class="field">
          <label>Status</label>
          <select id="status" onchange="markDirty()">
            <option value="online">Online</option>
            <option value="idle">Idle</option>
            <option value="dnd">Do Not Disturb</option>
            <option value="invisible">Invisible</option>
          </select>
        </div>
        <div class="toggle-row">
          <div>
            <strong>Enable RPC</strong>
            <div style="font-size:0.75rem; color:var(--text-dim)">Show custom activity on profile</div>
          </div>
          <label class="switch"><input type="checkbox" id="rpc_enabled" onchange="markDirty()"><span class="slider"></span></label>
        </div>
      </div>

      <div class="card">
        <div class="card-title"><i class="fas fa-eye"></i> Live Preview</div>
        <div class="preview">
          <div id="prevImg" class="prev-img"><i class="fas fa-image"></i></div>
          <div>
            <div id="prevType" class="prev-type">PLAYING</div>
            <div id="prevName" class="prev-name">Onyx</div>
            <div id="prevDetails" class="prev-details"></div>
            <div id="prevState" class="prev-state"></div>
          </div>
        </div>
        <div style="margin-top: 20px" class="field">
          <label>Activity Type</label>
          <select id="rpc_type" onchange="markDirty();toggleStreamUrl();updatePreview()">
            <option value="PLAYING">Playing</option>
            <option value="STREAMING">Streaming</option>
            <option value="LISTENING">Listening to</option>
            <option value="WATCHING">Watching</option>
            <option value="COMPETING">Competing in</option>
          </select>
        </div>
        <div class="field">
          <label>Activity Name</label>
          <input type="text" id="rpc_name" placeholder="Onyx" oninput="markDirty();updatePreview()">
        </div>
      </div>

      <div class="card">
        <div class="card-title"><i class="fas fa-info-circle"></i> RPC Details</div>
        <div class="field">
          <label>Application ID</label>
          <input type="text" id="rpc_application_id" placeholder="e.g. 123456789012345678" oninput="markDirty()">
        </div>
        <div class="field">
          <label>Details</label>
          <input type="text" id="rpc_details" placeholder="What are you doing?" oninput="markDirty();updatePreview()">
        </div>
        <div class="field">
          <label>State</label>
          <input type="text" id="rpc_state" placeholder="Current state" oninput="markDirty();updatePreview()">
        </div>
        <div id="streamUrlField" class="field" style="display:none">
          <label>Twitch URL</label>
          <input type="text" id="rpc_stream_url" placeholder="https://twitch.tv/..." oninput="markDirty()">
        </div>
        <div class="toggle-row">
          <div><strong>Show Elapsed Time</strong></div>
          <label class="switch"><input type="checkbox" id="rpc_show_elapsed" onchange="markDirty()"><span class="slider"></span></label>
        </div>
      </div>

      <div class="card">
        <div class="card-title"><i class="fas fa-image"></i> Assets</div>
        <div class="field">
          <label>Large Image (URL or Key)</label>
          <input type="text" id="rpc_large_image" placeholder="https://... or asset key" oninput="markDirty();updatePreview()">
        </div>
        <div class="field">
          <label>Large Image Text</label>
          <input type="text" id="rpc_large_text" placeholder="Hover tooltip" oninput="markDirty()">
        </div>
        <div class="field">
          <label>Small Image (URL or Key)</label>
          <input type="text" id="rpc_small_image" placeholder="https://... or asset key" oninput="markDirty()">
        </div>
        <div class="field">
          <label>Small Image Text</label>
          <input type="text" id="rpc_small_text" placeholder="Hover tooltip" oninput="markDirty()">
        </div>
      </div>

      <div class="card">
        <div class="card-title"><i class="fas fa-link"></i> Buttons</div>
        <div class="field">
          <label>Button 1 Label</label>
          <input type="text" id="rpc_button1_text" placeholder="Visit Website" oninput="markDirty()">
        </div>
        <div class="field">
          <label>Button 1 URL</label>
          <input type="text" id="rpc_button1_url" placeholder="https://..." oninput="markDirty()">
        </div>
        <hr style="border-color:var(--border);margin:16px 0">
        <div class="field">
          <label>Button 2 Label</label>
          <input type="text" id="rpc_button2_text" placeholder="Join Server" oninput="markDirty()">
        </div>
        <div class="field">
          <label>Button 2 URL</label>
          <input type="text" id="rpc_button2_url" placeholder="https://..." oninput="markDirty()">
        </div>
      </div>

      <div class="card">
        <div class="card-title"><i class="fas fa-comment-dots"></i> Custom Status</div>
        <div class="toggle-row">
          <div>
            <strong>Enable Custom Status</strong>
            <div style="font-size:0.75rem; color:var(--text-dim)">Shows text & emoji under your username</div>
          </div>
          <label class="switch"><input type="checkbox" id="custom_status_enabled" onchange="markDirty()"><span class="slider"></span></label>
        </div>
        <div class="field" style="margin-top:15px">
          <label>Status Text</label>
          <input type="text" id="custom_status_text" placeholder="Vibing..." oninput="markDirty()">
        </div>
        <div class="field">
          <label>Emoji</label>
          <input type="text" id="custom_status_emoji" placeholder="🎮 or <:name:id>" oninput="markDirty()">
        </div>
      </div>
    </div>
  </div>

  <!-- Quests Section -->
  <div id="quests" class="section">
    <div class="header">
      <h2>Discord Quests</h2>
      <div style="display:flex; gap:10px">
        <button class="btn btn-ghost" onclick="loadQuests()"><i class="fas fa-sync"></i> Refresh</button>
        <button id="startAllBtn" class="btn btn-primary" onclick="startAllQuests()"><i class="fas fa-play"></i> Start All</button>
        <button id="stopBtn" class="btn btn-danger" style="display:none" onclick="stopQuests()"><i class="fas fa-stop"></i> Stop</button>
      </div>
    </div>
    
    <div id="questBanner" class="status-card" style="display:none; border-color: var(--accent)">
      <div class="dot dot-g"></div>
      <div id="questBannerText" class="status-info">Running quests...</div>
    </div>

    <div class="grid">
      <div class="card">
        <div class="card-title"><i class="fas fa-list"></i> Available Quests</div>
        <div id="questList" class="quest-list">
          <div class="quest-empty">Loading quests...</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-terminal"></i> Protocol Logs</div>
        <div id="questLog" class="quest-log">
          <span style="color:var(--text-muted)">Waiting for protocol start...</span>
        </div>
        <button class="btn btn-ghost btn-sm" style="margin-top:10px" onclick="clearQuestLogs()">Clear Logs</button>
      </div>
    </div>
  </div>

  <!-- Automation Section -->
  <div id="automation" class="section">
    <div class="header"><h2>Automation Features</h2></div>
    <div class="grid">
      <div class="card">
        <div class="card-title"><i class="fas fa-moon"></i> AFK Mode</div>
        <div class="toggle-row">
          <div><strong>Enable AFK</strong><small style="display:block;color:var(--text-dim)">Auto-reply to DMs when active</small></div>
          <label class="switch"><input type="checkbox" id="afk_enabled"><span class="slider"></span></label>
        </div>
        <div class="field" style="margin-top:15px">
          <label>AFK Message</label>
          <textarea id="afk_msg" placeholder="I am currently AFK..."></textarea>
        </div>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-bolt"></i> Auto-Features</div>
        <div class="toggle-row">
          <div><strong>Auto-React</strong><small style="display:block;color:var(--text-dim)">React to messages in specific channels</small></div>
          <label class="switch"><input type="checkbox" id="react_enabled"><span class="slider"></span></label>
        </div>
        <div class="toggle-row">
          <div><strong>Auto-Reply</strong><small style="display:block;color:var(--text-dim)">Reply to keywords automatically</small></div>
          <label class="switch"><input type="checkbox" id="reply_enabled"><span class="slider"></span></label>
        </div>
      </div>
    </div>
  </div>

  <!-- Messages Section -->
  <div id="messages" class="section">
    <div class="header"><h2>Message Scheduler</h2></div>
    <div class="grid">
      <div class="card">
        <div class="card-title"><i class="fas fa-clock"></i> Schedule One-Time</div>
        <div class="field"><label>Target ID (Channel/User)</label><input type="text" id="sch_target"></div>
        <div class="field"><label>Run At</label><input type="datetime-local" id="sch_when"></div>
        <div class="field"><label>Message Content</label><textarea id="sch_msg"></textarea></div>
        <button class="btn btn-primary" onclick="addScheduled()">Schedule Message</button>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-redo"></i> Recurring Messages</div>
        <div class="field"><label>Target ID</label><input type="text" id="rec_target"></div>
        <div class="field"><label>Interval (Minutes)</label><input type="number" id="rec_interval" value="60"></div>
        <div class="field"><label>Message Content</label><textarea id="rec_msg"></textarea></div>
        <button class="btn btn-primary" onclick="addRecurring()">Add Recurring</button>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-list"></i> Scheduled Queue</div>
        <div id="sch_list" class="row-list"></div>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-list"></i> Recurring Queue</div>
        <div id="rec_list" class="row-list"></div>
      </div>
    </div>
  </div>

  <!-- Utility Section -->
  <div id="utility" class="section">
    <div class="header"><h2>Utility Tools</h2></div>
    <div class="grid">
      <div class="card">
        <div class="card-title"><i class="fas fa-trash"></i> Message Purge</div>
        <div class="field"><label>Channel ID</label><input type="text" id="purge_channel"></div>
        <div class="field"><label>Count</label><input type="number" id="purge_count" value="100"></div>
        <button class="btn btn-danger" onclick="runPurge()">Purge My Messages</button>
      </div>
      <div class="card">
        <div class="card-title"><i class="fas fa-paper-plane"></i> Quick Send</div>
        <div class="field"><label>Target ID</label><input type="text" id="send_target"></div>
        <div class="field"><label>Message</label><textarea id="send_msg"></textarea></div>
        <button class="btn btn-primary" onclick="runSend()">Send Now</button>
      </div>
    </div>
  </div>
</div>

<div id="saveBar" class="save-bar">
  <div style="color:var(--text-dim); font-size:0.9rem">You have unsaved changes</div>
  <div style="display:flex; gap:10px">
    <button class="btn btn-ghost" onclick="resetForm()">Discard</button>
    <button class="btn btn-primary" onclick="saveAll()">Save Changes</button>
  </div>
</div>

<script>
const $ = id => document.getElementById(id);
const gv = id => $(id).value;
const sv = (id, v) => $(id).value = v;
const gc = id => $(id).checked;
const sc = (id, v) => $(id).checked = !!v;

let isDirty = false;

function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  $(id).classList.add('active');
  event.currentTarget.classList.add('active');
  if(id === 'quests') loadQuests();
  if(id === 'messages') loadMessages();
  if(id === 'automation') loadAuto();
}

function markDirty() {
  isDirty = true;
  $('saveBar').classList.add('active');
}

function resetDirty() {
  isDirty = false;
  $('saveBar').classList.remove('active');
}

async function loadForm() {
  try {
    const d = await fetch('/api/config').then(r => r.json());
    if (!d.success) return;
    const c = d.config;
    sv('token', c.token || '');
    sv('status', c.status || 'online');
    sc('rpc_enabled', c.rpc?.enabled);
    sv('rpc_type', c.rpc?.type || 'PLAYING');
    sv('rpc_name', c.rpc?.name || '');
    sv('rpc_application_id', c.rpc?.application_id || '');
    sv('rpc_details', c.rpc?.details || '');
    sv('rpc_state', c.rpc?.state || '');
    sv('rpc_stream_url', c.rpc?.stream_url || '');
    sc('rpc_show_elapsed', c.rpc?.show_elapsed);
    sv('rpc_large_image', c.rpc?.large_image || '');
    sv('rpc_large_text', c.rpc?.large_text || '');
    sv('rpc_small_image', c.rpc?.small_image || '');
    sv('rpc_small_text', c.rpc?.small_text || '');
    sv('rpc_button1_text', c.rpc?.button1_text || '');
    sv('rpc_button1_url', c.rpc?.button1_url || '');
    sv('rpc_button2_text', c.rpc?.button2_text || '');
    sv('rpc_button2_url', c.rpc?.button2_url || '');
    sc('custom_status_enabled', c.custom_status?.enabled);
    sv('custom_status_text', c.custom_status?.text || '');
    sv('custom_status_emoji', c.custom_status?.emoji || '');
    
    updatePreview();
    toggleStreamUrl();
    pollStatus();
    setInterval(pollStatus, 5000);
  } catch (e) {}
}

async function saveAll() {
  const body = {
    status: gv('status'),
    rpc: {
      enabled: gc('rpc_enabled'),
      type: gv('rpc_type'),
      name: gv('rpc_name'),
      application_id: gv('rpc_application_id'),
      details: gv('rpc_details'),
      state: gv('rpc_state'),
      stream_url: gv('rpc_stream_url'),
      show_elapsed: gc('rpc_show_elapsed'),
      large_image: gv('rpc_large_image'),
      large_text: gv('rpc_large_text'),
      small_image: gv('rpc_small_image'),
      small_text: gv('rpc_small_text'),
      button1_text: gv('rpc_button1_text'),
      button1_url: gv('rpc_button1_url'),
      button2_text: gv('rpc_button2_text'),
      button2_url: gv('rpc_button2_url')
    },
    custom_status: {
      enabled: gc('custom_status_enabled'),
      text: gv('custom_status_text'),
      emoji: gv('custom_status_emoji')
    }
  };
  const d = await fetch('/api/config', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  }).then(r => r.json());
  if (d.success) {
    toast('Settings saved!', true);
    resetDirty();
  } else toast(d.error, false);
}

async function saveToken() {
  const token = gv('token');
  const d = await fetch('/api/config', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ token })
  }).then(r => r.json());
  if (d.success) toast('Token updated!', true);
  else toast(d.error, false);
}

async function pollStatus() {
  try {
    const d = await fetch('/api/status').then(r => r.json());
    const dot = $('statusDot'), tag = $('statusTag'), sub = $('statusSub'), btn = $('connectBtn');
    dot.className = 'dot ' + (d.state === 'connected' ? 'dot-g' : d.state === 'connecting' ? 'dot-y' : 'dot-r');
    tag.textContent = d.state.toUpperCase();
    sub.textContent = d.state === 'connected' ? `Logged in as ${d.tag}` : d.error || 'Disconnected from Discord';
    btn.innerHTML = d.state === 'connected' ? '<i class="fas fa-stop"></i> Disconnect' : '<i class="fas fa-plug"></i> Connect';
    btn.className = 'btn ' + (d.state === 'connected' ? 'btn-danger' : 'btn-primary');
  } catch (e) {}
}

async function toggleConnect() {
  const d = await fetch('/api/status').then(r => r.json());
  if (d.state === 'connected') await fetch('/api/stop', { method: 'POST' });
  else await fetch('/api/start', { method: 'POST' });
  pollStatus();
}

function updatePreview() {
  const type = gv('rpc_type'), name = gv('rpc_name') || 'Onyx', det = gv('rpc_details'), st = gv('rpc_state'), img = gv('rpc_large_image');
  $('prevType').textContent = type;
  $('prevName').textContent = name;
  const de = $('prevDetails'), se = $('prevState');
  de.textContent = det; de.style.display = det ? 'block' : 'none';
  se.textContent = st; se.style.display = st ? 'block' : 'none';
  const pi = $('prevImg');
  pi.innerHTML = img ? `<img src="${img}" onerror="this.parentElement.innerHTML='<i class=\\'fas fa-image\\'></i>'">` : '<i class="fas fa-image"></i>';
}

function toggleStreamUrl() {
  $('streamUrlField').style.display = gv('rpc_type') === 'STREAMING' ? 'block' : 'none';
}

function toast(msg, ok) {
  const t = document.createElement('div');
  t.className = 'toast ' + (ok ? 'tok' : 'terr'); t.textContent = msg;
  document.body.appendChild(t); setTimeout(() => t.remove(), 3000);
}

// ── Quests ──
let questPollTimer = null;
let lastLogCount = 0;
let cachedQuests = [];

async function loadQuests() {
  const list = $('questList');
  list.innerHTML = '<div class="quest-empty"><i class="fas fa-spinner fa-spin"></i> Loading...</div>';
  try {
    const d = await fetch('/api/quests').then(r => r.json());
    if (d.success) { cachedQuests = d.quests; renderQuestList(d.quests); }
    else list.innerHTML = `<div class="quest-empty" style="color:var(--red)">${d.error}</div>`;
  } catch (e) {}
}

function renderQuestList(quests) {
  const list = $('questList');
  if (!quests.length) { list.innerHTML = '<div class="quest-empty">No quests available</div>'; return; }
  list.innerHTML = quests.map(q => {
    const icon = q.appId ? `<img src="https://cdn.discordapp.com/app-icons/${q.appId}/a_.png" onerror="this.parentElement.innerHTML='<i class=\\'fas fa-gamepad\\'></i>'">` : '<i class="fas fa-gamepad"></i>';
    return `<div class="quest-item" id="qi-${q.id}">
      <div class="quest-icon">${icon}</div>
      <div class="quest-info">
        <div style="font-weight:700">${q.name}</div>
        <div style="font-size:0.75rem; color:var(--text-dim)">${q.game || ''} • ${q.type}</div>
      </div>
      ${!q.completed && !q.expired ? `<button class="btn btn-ghost btn-sm" onclick="startQuest('${q.id}')">Start</button>` : `<span class="tag">${q.completed ? 'Done' : 'Expired'}</span>`}
    </div>`;
  }).join('');
}

async function startQuest(questId) {
  await fetch('/api/quests/start', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ questId }) });
  startQuestPoll();
}

async function startAllQuests() {
  await fetch('/api/quests/start', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
  startQuestPoll();
}

async function stopQuests() { await fetch('/api/quests/stop', { method: 'POST' }); }
async function clearQuestLogs() { await fetch('/api/quests/clear-logs', { method: 'POST' }); $('questLog').innerHTML = ''; lastLogCount = 0; }

function startQuestPoll() {
  if (questPollTimer) return;
  questPollTimer = setInterval(pollQuestStatus, 1500);
}

async function pollQuestStatus() {
  try {
    const d = await fetch('/api/quests/status').then(r => r.json());
    const banner = $('questBanner'), bText = $('questBannerText');
    if (d.isRunning) {
      banner.style.display = 'flex';
      bText.textContent = d.currentQuest ? `Running: ${d.currentQuest.name}` : 'Running quests...';
      $('startAllBtn').style.display = 'none'; $('stopBtn').style.display = 'inline-flex';
    } else {
      banner.style.display = 'none';
      $('startAllBtn').style.display = 'inline-flex'; $('stopBtn').style.display = 'none';
      if (questPollTimer) { clearInterval(questPollTimer); questPollTimer = null; }
    }
    if (d.logs && d.logs.length > lastLogCount) {
      const logEl = $('questLog');
      d.logs.slice(lastLogCount).forEach(line => {
        const div = document.createElement('div');
        div.textContent = line;
        logEl.appendChild(div);
      });
      lastLogCount = d.logs.length;
      logEl.scrollTop = logEl.scrollHeight;
    }
  } catch (e) {}
}

// ── Messages ──
async function loadMessages() {
  const d = await fetch('/api/messages').then(r => r.json());
  renderList($('sch_list'), d.scheduled, deleteScheduled);
  renderList($('rec_list'), d.recurring, deleteRecurring);
}

function renderList(el, list, delFn) {
  if (!list || !list.length) { el.innerHTML = '<div style="text-align:center; padding:20px; color:var(--text-muted)">Empty</div>'; return; }
  el.innerHTML = list.map(e => `<div class="row-item">
    <div class="ri-main">
      <div style="font-size:0.85rem"><span class="tag">${e.targetId}</span> ${e.runAt ? new Date(e.runAt).toLocaleString() : 'Every ' + e.intervalMin + 'm'}</div>
      <div style="font-size:0.75rem; color:var(--text-dim); margin-top:4px">${e.message}</div>
    </div>
    <button class="btn btn-danger btn-sm" onclick="${delFn.name}('${e.id}')"><i class="fas fa-trash"></i></button>
  </div>`).join('');
}

async function addScheduled() {
  const targetId = gv('sch_target'), runAt = gv('sch_when'), message = gv('sch_msg');
  if (!targetId || !runAt || !message) return toast('Fill all fields', false);
  const d = await fetch('/api/messages/scheduled', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetId, runAt, message }) }).then(r => r.json());
  if (d.success) { toast('Scheduled!', true); loadMessages(); sv('sch_msg', ''); }
  else toast(d.error, false);
}

async function addRecurring() {
  const targetId = gv('rec_target'), intervalMin = parseInt(gv('rec_interval')), message = gv('rec_msg');
  if (!targetId || !intervalMin || !message) return toast('Fill all fields', false);
  const d = await fetch('/api/messages/recurring', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetId, intervalMin, message }) }).then(r => r.json());
  if (d.success) { toast('Added!', true); loadMessages(); sv('rec_msg', ''); }
  else toast(d.error, false);
}

async function deleteScheduled(id) { await fetch('/api/messages/scheduled/' + id, { method: 'DELETE' }); loadMessages(); }
async function deleteRecurring(id) { await fetch('/api/messages/recurring/' + id, { method: 'DELETE' }); loadMessages(); }

// ── Automation ──
async function loadAuto() {
  const d = await fetch('/api/auto').then(r => r.json());
  if (d.success) {
    sc('afk_enabled', d.config.afk?.enabled);
    sv('afk_msg', d.config.afk?.message || '');
    sc('react_enabled', d.config.autoReact?.enabled);
    sc('reply_enabled', d.config.autoReply?.enabled);
  }
  ['afk_enabled', 'react_enabled', 'reply_enabled'].forEach(id => $(id).onchange = saveAuto);
  $('afk_msg').onblur = saveAuto;
}

async function saveAuto() {
  const body = {
    afk: { enabled: gc('afk_enabled'), message: gv('afk_msg') },
    autoReact: { enabled: gc('react_enabled') },
    autoReply: { enabled: gc('reply_enabled') }
  };
  await fetch('/api/auto', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
}

// ── Utility ──
async function runPurge() {
  const channelId = gv('purge_channel'), count = parseInt(gv('purge_count'));
  const d = await fetch('/api/util/purge', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ channelId, count }) }).then(r => r.json());
  if (d.success) toast(`Purged ${d.deleted} messages`, true);
  else toast(d.error, false);
}

async function runSend() {
  const targetId = gv('send_target'), message = gv('send_msg');
  const d = await fetch('/api/util/send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetId, message }) }).then(r => r.json());
  if (d.success) toast('Sent!', true);
  else toast(d.error, false);
}

window.onload = loadForm;
</script>
</body>
</html>
