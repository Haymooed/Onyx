<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>RPcustom Panel</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" href="/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:'Space Grotesk',sans-serif}
:root{
  --bg:#06080f;--surface:#0b1020;--surface2:#0f1829;--surface3:#131e35;
  --border:rgba(0,160,255,.14);--border-hover:rgba(0,160,255,.3);
  --accent:#0090ff;--accent2:#0050ff;--accent-glow:rgba(0,144,255,.25);
  --text:#d8e4f8;--text-dim:#4a5e80;--text-muted:#2e3e58;
  --green:#00d97e;--red:#ff4d4d;--yellow:#ffaa00;
}
body{background:var(--bg);color:var(--text);min-height:100vh;padding:20px 16px 72px;
  background-image:radial-gradient(ellipse at 0% 0%,rgba(0,100,255,.06) 0%,transparent 40%),
                   radial-gradient(ellipse at 100% 100%,rgba(0,60,200,.04) 0%,transparent 40%)}
.topbar{max-width:880px;margin:0 auto 20px;display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:10px}
.brand-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--accent2),var(--accent));
  border-radius:10px;display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 16px var(--accent-glow)}
.brand-icon svg{width:18px;height:18px;fill:#fff}
.brand h1{font-size:1.2rem;font-weight:700;letter-spacing:-.02em;
  background:linear-gradient(90deg,#fff,#7ab8ff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.topbar-right{display:flex;align-items:center;gap:14px}
.topbar-right a{color:var(--text-dim);font-size:.78rem;text-decoration:none;transition:.2s;display:flex;align-items:center;gap:5px}
.topbar-right a:hover{color:var(--text)}
.wrap{max-width:880px;margin:0 auto;display:grid;gap:14px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:22px}
.card-title{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;
  color:var(--accent);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.card-title i{font-size:.75rem;opacity:.8}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:560px){.grid2{grid-template-columns:1fr}}
.field label{display:block;font-size:.67rem;color:var(--text-dim);font-weight:700;
  text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
input[type=text],input[type=password],input[type=url],select{
  width:100%;padding:9px 12px;background:var(--surface2);border:1px solid var(--border);
  border-radius:8px;color:var(--text);font-size:.88rem;outline:none;transition:.2s;font-family:inherit}
input::placeholder{color:var(--text-muted)}
input:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,144,255,.1)}
select option{background:var(--surface2)}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.toggle-row:last-child{border-bottom:none;padding-bottom:0}
.tl-label{font-size:.85rem;line-height:1.4}
.tl-label small{display:block;color:var(--text-dim);font-size:.72rem;margin-top:2px}
.switch{position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0}
.switch input{opacity:0;width:0;height:0}
.slider{position:absolute;inset:0;background:var(--surface3);border-radius:22px;cursor:pointer;transition:.25s;border:1px solid var(--border)}
.slider:before{content:'';position:absolute;width:14px;height:14px;left:3px;bottom:3px;background:#3a4a65;border-radius:50%;transition:.25s}
input:checked+.slider{background:var(--accent2);border-color:var(--accent)}
input:checked+.slider:before{transform:translateX(18px);background:#fff}
.sep{border:none;border-top:1px solid rgba(255,255,255,.05);margin:14px 0}
.conn-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;transition:.3s}
.dot-g{background:var(--green);box-shadow:0 0 8px var(--green)}
.dot-y{background:var(--yellow);box-shadow:0 0 8px var(--yellow)}
.dot-r{background:var(--red);box-shadow:0 0 8px var(--red)}
.dot-gray{background:#2a3a55}
.conn-tag{font-size:.88rem;color:#fff;font-weight:600}
.conn-sub{font-size:.72rem;color:var(--text-dim)}
.token-row{display:flex;gap:8px}
.token-row input{flex:1}
.note{font-size:.68rem;color:var(--text-muted);margin-top:8px;display:flex;align-items:center;gap:5px}
.btn{padding:9px 18px;border:none;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;
  transition:.2s;font-family:inherit;display:inline-flex;align-items:center;gap:6px;letter-spacing:.01em}
.btn-primary{background:linear-gradient(90deg,var(--accent2),var(--accent));color:#fff;
  box-shadow:0 3px 14px var(--accent-glow)}
.btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 6px 22px rgba(0,144,255,.4)}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-ghost{background:rgba(0,160,255,.07);border:1px solid var(--border);color:var(--accent)}
.btn-ghost:hover{background:rgba(0,160,255,.13);border-color:var(--border-hover)}
.btn-danger{background:rgba(255,60,60,.08);border:1px solid rgba(255,60,60,.2);color:var(--red)}
.btn-danger:hover{background:rgba(255,60,60,.16)}
.btn-sm{padding:6px 12px;font-size:.76rem}
.preview{background:var(--surface2);border:1px solid rgba(255,255,255,.06);border-radius:10px;
  padding:14px;display:flex;gap:12px;align-items:flex-start;margin-top:14px}
.prev-img{width:56px;height:56px;border-radius:8px;background:var(--surface3);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:1.2rem;overflow:hidden}
.prev-img img{width:100%;height:100%;object-fit:cover;border-radius:8px}
.prev-type{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text-dim);margin-bottom:3px}
.prev-name{font-size:.92rem;font-weight:700;color:#fff}
.prev-details,.prev-state{font-size:.78rem;color:#8899bb;margin-top:2px}
.save-bar{position:fixed;bottom:0;left:0;right:0;padding:12px 20px;
  background:rgba(6,8,15,.95);border-top:1px solid rgba(0,160,255,.1);backdrop-filter:blur(16px);
  display:flex;align-items:center;justify-content:space-between;z-index:99}
.save-bar .hint{font-size:.75rem;color:var(--text-dim)}
.toast{position:fixed;top:16px;right:16px;padding:10px 16px;border-radius:9px;font-size:.82rem;
  font-weight:600;z-index:200;animation:tin .25s ease;pointer-events:none}
.tok{background:#0a2a1a;border:1px solid var(--green);color:var(--green)}
.terr{background:#2a0a0a;border:1px solid var(--red);color:var(--red)}
@keyframes tin{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

/* ── Quest Styles ── */
.quest-toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.quest-list{display:grid;gap:8px;margin-bottom:14px}
.quest-item{background:var(--surface2);border:1px solid var(--border);border-radius:10px;
  padding:12px 14px;display:flex;align-items:center;gap:12px;transition:.2s}
.quest-item:hover{border-color:var(--border-hover)}
.quest-item.completed{opacity:.45}
.quest-item.running{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,144,255,.12)}
.quest-icon{width:40px;height:40px;border-radius:8px;background:var(--surface3);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:1.1rem;overflow:hidden}
.quest-icon img{width:100%;height:100%;object-fit:cover;border-radius:8px}
.quest-info{flex:1;min-width:0}
.quest-name{font-size:.88rem;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.quest-meta{font-size:.7rem;color:var(--text-dim);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:99px;font-size:.65rem;font-weight:700}
.badge-play{background:rgba(0,144,255,.1);color:var(--accent)}
.badge-video{background:rgba(255,170,0,.1);color:var(--yellow)}
.badge-done{background:rgba(0,217,126,.1);color:var(--green)}
.badge-exp{background:rgba(255,77,77,.1);color:var(--red)}
.quest-log{background:#060c18;border:1px solid var(--border);border-radius:10px;
  padding:12px;height:200px;overflow-y:auto;font-family:monospace;font-size:.74rem;
  color:#6a8aaa;line-height:1.6;scroll-behavior:smooth}
.quest-log .log-line{margin-bottom:1px}
.quest-log .log-done{color:var(--green)}
.quest-log .log-err{color:var(--red)}
.quest-log .log-info{color:#7ab8ff}
.quest-running-banner{display:none;align-items:center;gap:8px;padding:8px 12px;
  background:rgba(0,144,255,.07);border:1px solid rgba(0,144,255,.2);border-radius:8px;margin-bottom:12px}
.quest-running-banner.active{display:flex}
.spinner{display:inline-block;width:12px;height:12px;border:2px solid rgba(0,144,255,.3);
  border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.quest-empty{text-align:center;padding:24px;color:var(--text-dim);font-size:.82rem}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="brand-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
    </div>
    <h1>RPcustom</h1>
  </div>
  <div class="topbar-right">
    <a href="/logout"><i class="fas fa-right-from-bracket"></i> Logout</a>
  </div>
</div>

<div class="wrap">

  <!-- Connection -->
  <div class="card">
    <div class="card-title"><i class="fas fa-plug"></i> Discord Connection</div>
    <div class="conn-row">
      <span class="dot dot-gray" id="connDot"></span>
      <span class="conn-tag" id="connTag">Not connected</span>
      <span class="conn-sub" id="connSub"></span>
    </div>
    <div class="token-row field">
      <input type="password" id="tokenInput" placeholder="Paste your Discord token…">
      <button class="btn btn-primary" id="connectBtn" onclick="connectAcc()"><i class="fas fa-bolt"></i> Connect</button>
      <button class="btn btn-danger" id="disconnectBtn" onclick="disconnectAcc()" style="display:none"><i class="fas fa-xmark"></i> Disconnect</button>
    </div>
    <p class="note"><i class="fas fa-lock"></i> Token is stored only in config.yml on your machine</p>
  </div>

  <!-- Presence Settings -->
  <div class="card">
    <div class="card-title"><i class="fas fa-sliders"></i> Presence Settings</div>
    <div class="toggle-row">
      <div class="tl-label">Enable Rich Presence<small>Show a custom activity on your Discord profile</small></div>
      <label class="switch"><input type="checkbox" id="rpc_enabled" onchange="livePreview()"><span class="slider"></span></label>
    </div>
    <hr class="sep">
    <div class="grid2">
      <div class="field"><label>Activity Type</label>
        <select id="rpc_type" onchange="livePreview();toggleStreamUrl()">
          <option value="PLAYING">🎮 Playing</option>
          <option value="LISTENING">🎵 Listening</option>
          <option value="WATCHING">📺 Watching</option>
          <option value="STREAMING">📡 Streaming</option>
          <option value="COMPETING">🏆 Competing</option>
        </select>
      </div>
      <div class="field"><label>Online Status</label>
        <select id="status">
          <option value="online">🟢 Online</option>
          <option value="idle">🌙 Idle</option>
          <option value="dnd">🔴 Do Not Disturb</option>
          <option value="invisible">⚫ Invisible</option>
        </select>
      </div>
    </div>
    <div class="grid2" style="margin-top:12px">
      <div class="field"><label>App Name</label><input type="text" id="rpc_name" placeholder="RPcustom" oninput="livePreview()"></div>
      <div class="field"><label>Application ID <span style="color:var(--text-muted)">(optional)</span></label><input type="text" id="rpc_application_id" placeholder="Discord App ID"></div>
    </div>
    <div class="grid2" style="margin-top:12px">
      <div class="field"><label>Details (line 1)</label><input type="text" id="rpc_details" placeholder="Doing something cool" oninput="livePreview()"></div>
      <div class="field"><label>State (line 2)</label><input type="text" id="rpc_state" placeholder="with RPcustom" oninput="livePreview()"></div>
    </div>
    <div class="toggle-row" style="margin-top:10px">
      <div class="tl-label">Show Elapsed Timer<small>Displays how long the activity has been active</small></div>
      <label class="switch"><input type="checkbox" id="rpc_show_elapsed"><span class="slider"></span></label>
    </div>
    <div class="field" id="streamUrlField" style="margin-top:12px;display:none">
      <label>Stream URL</label><input type="url" id="rpc_stream_url" placeholder="https://twitch.tv/yourchannel">
    </div>
  </div>

  <!-- Images -->
  <div class="card">
    <div class="card-title"><i class="fas fa-image"></i> Images</div>
    <div class="grid2">
      <div class="field"><label>Large Image URL</label><input type="url" id="rpc_large_image" placeholder="https://i.imgur.com/…" oninput="livePreview()"></div>
      <div class="field"><label>Large Image Hover Text</label><input type="text" id="rpc_large_text" placeholder="Hover text…"></div>
      <div class="field"><label>Small Image URL</label><input type="url" id="rpc_small_image" placeholder="https://i.imgur.com/…"></div>
      <div class="field"><label>Small Image Hover Text</label><input type="text" id="rpc_small_text" placeholder="Hover text…"></div>
    </div>
    <div class="preview">
      <div class="prev-img" id="prevImg"><i class="fas fa-image"></i></div>
      <div>
        <div class="prev-type" id="prevType">PLAYING</div>
        <div class="prev-name" id="prevName">RPcustom</div>
        <div class="prev-details" id="prevDetails" style="display:none"></div>
        <div class="prev-state" id="prevState" style="display:none"></div>
      </div>
    </div>
  </div>

  <!-- Buttons -->
  <div class="card">
    <div class="card-title"><i class="fas fa-link"></i> Buttons</div>
    <div class="grid2">
      <div class="field"><label>Button 1 Text</label><input type="text" id="rpc_button1_text" placeholder="Visit Website"></div>
      <div class="field"><label>Button 1 URL</label><input type="url" id="rpc_button1_url" placeholder="https://…"></div>
      <div class="field"><label>Button 2 Text</label><input type="text" id="rpc_button2_text" placeholder="Join Server"></div>
      <div class="field"><label>Button 2 URL</label><input type="url" id="rpc_button2_url" placeholder="https://…"></div>
    </div>
  </div>

  <!-- Spoofing -->
  <div class="card">
    <div class="card-title"><i class="fas fa-mask"></i> Spoofing</div>
    <div class="grid2">
      <div class="field"><label>Game Spoof <span style="color:var(--text-muted)">(overrides fields above)</span></label>
        <select id="rpc_spoof_game">
          <option value="none">None</option>
          <option value="minecraft">Minecraft</option>
          <option value="genshin">Genshin Impact</option>
        </select>
      </div>
      <div class="field"><label>App Spoof</label>
        <select id="rpc_spoof_app">
          <option value="none">None</option>
          <option value="crunchyroll">Crunchyroll</option>
          <option value="playstation">PlayStation 5</option>
        </select>
      </div>
    </div>
  </div>

  <!-- ── QUESTS ── -->
  <div class="card">
    <div class="card-title"><i class="fas fa-scroll"></i> Discord Quests
      <span style="margin-left:auto;font-size:.6rem;color:var(--text-muted);text-transform:none;letter-spacing:0;font-weight:400">
        Completes one quest at a time • Shows game in your Discord status
      </span>
    </div>

    <!-- Running banner -->
    <div class="quest-running-banner" id="questBanner">
      <span class="spinner"></span>
      <span id="questBannerText">Running quest…</span>
    </div>

    <!-- Toolbar -->
    <div class="quest-toolbar">
      <button class="btn btn-ghost btn-sm" onclick="loadQuests()"><i class="fas fa-rotate"></i> Refresh</button>
      <button class="btn btn-primary btn-sm" id="startAllBtn" onclick="startAllQuests()"><i class="fas fa-play"></i> Start All</button>
      <button class="btn btn-danger btn-sm" id="stopBtn" onclick="stopQuests()" style="display:none"><i class="fas fa-stop"></i> Stop</button>
      <button class="btn btn-ghost btn-sm" onclick="clearQuestLogs()" style="margin-left:auto"><i class="fas fa-trash"></i> Clear Logs</button>
    </div>

    <!-- Quest list -->
    <div class="quest-list" id="questList">
      <div class="quest-empty"><i class="fas fa-circle-info" style="margin-right:6px"></i>Click Refresh to load your available quests</div>
    </div>

    <!-- Log output -->
    <div class="quest-log" id="questLog"><span style="color:var(--text-muted)">Logs will appear here…</span></div>
  </div>

</div>

<div class="save-bar">
  <span class="hint" id="saveHint">Make changes then save</span>
  <button class="btn btn-primary" id="saveBtn" onclick="saveAll()"><i class="fas fa-floppy-disk"></i> Save &amp; Apply</button>
</div>

<script>
const $=id=>document.getElementById(id);
const gv=id=>($( id)||{}).value||'';
const gc=id=>!!($( id)||{}).checked;
const sv=(id,v)=>{const e=$(id);if(e)e.value=v};
const sc=(id,v)=>{const e=$(id);if(e)e.checked=!!v};

// ── RPC Form ──────────────────────────────────────────────────────────────────
async function loadForm(){
  const cfg=await fetch('/api/config').then(r=>r.json());
  const r=cfg.rpc||{};
  sv('tokenInput',cfg.token?'••••••••••••':'');
  sc('rpc_enabled',r.enabled!==false);
  sv('rpc_type',r.type||'PLAYING');
  sv('status',cfg.status||'online');
  sv('rpc_name',r.name||'');
  sv('rpc_application_id',r.application_id||'');
  sv('rpc_details',r.details||'');
  sv('rpc_state',r.state||'');
  sc('rpc_show_elapsed',!!r.show_elapsed);
  sv('rpc_stream_url',r.stream_url||'');
  sv('rpc_large_image',r.large_image||'');
  sv('rpc_large_text',r.large_text||'');
  sv('rpc_small_image',r.small_image||'');
  sv('rpc_small_text',r.small_text||'');
  sv('rpc_button1_text',r.button1_text||'');
  sv('rpc_button1_url',r.button1_url||'');
  sv('rpc_button2_text',r.button2_text||'');
  sv('rpc_button2_url',r.button2_url||'');
  sv('rpc_spoof_game',r.spoof_game||'none');
  sv('rpc_spoof_app',r.spoof_app||'none');
  toggleStreamUrl(); livePreview(); pollStatus();
}

async function saveAll(){
  const btn=$('saveBtn');
  btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Saving…';
  const body={
    status:gv('status'),
    rpc:{
      enabled:gc('rpc_enabled'),type:gv('rpc_type'),name:gv('rpc_name'),
      application_id:gv('rpc_application_id'),details:gv('rpc_details'),state:gv('rpc_state'),
      show_elapsed:gc('rpc_show_elapsed'),stream_url:gv('rpc_stream_url'),
      large_image:gv('rpc_large_image'),large_text:gv('rpc_large_text'),
      small_image:gv('rpc_small_image'),small_text:gv('rpc_small_text'),
      button1_text:gv('rpc_button1_text'),button1_url:gv('rpc_button1_url'),
      button2_text:gv('rpc_button2_text'),button2_url:gv('rpc_button2_url'),
      spoof_game:gv('rpc_spoof_game'),spoof_app:gv('rpc_spoof_app')
    }
  };
  const d=await fetch('/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json());
  btn.disabled=false;btn.innerHTML='<i class="fas fa-floppy-disk"></i> Save &amp; Apply';
  if(d.success){toast('Saved & applied!',true);$('saveHint').textContent='Saved ✓';}
  else toast(d.error||'Save failed',false);
}

async function connectAcc(){
  const token=gv('tokenInput');
  if(!token||token.includes('•')){toast('Paste your actual Discord token first',false);return;}
  const btn=$('connectBtn');
  btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Connecting…';
  const d=await fetch('/api/connect',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token})}).then(r=>r.json());
  btn.disabled=false;btn.innerHTML='<i class="fas fa-bolt"></i> Connect';
  if(d.success){toast('Connected as '+d.tag,true);sv('tokenInput','••••••••••••');}
  else toast(d.error||'Login failed — check your token',false);
  pollStatus();
}

async function disconnectAcc(){
  await fetch('/api/disconnect',{method:'POST'});
  toast('Disconnected',true); pollStatus();
}

async function pollStatus(){
  const d=await fetch('/api/status').then(r=>r.json());
  const dot=$('connDot'),tag=$('connTag'),sub=$('connSub'),disc=$('disconnectBtn'),conn=$('connectBtn');
  dot.className='dot '+(d.state==='connected'?'dot-g':d.state==='connecting'?'dot-y':d.state==='error'?'dot-r':'dot-gray');
  tag.textContent=d.tag||(d.state==='error'?'Connection failed':'Not connected');
  sub.textContent=d.state==='error'?(d.error||'Error'):d.state;
  disc.style.display=d.state==='connected'?'inline-flex':'none';
  conn.style.display=d.state==='connected'?'none':'inline-flex';
}
setInterval(pollStatus,5000);

function livePreview(){
  const type=gv('rpc_type'),name=gv('rpc_name')||'RPcustom',det=gv('rpc_details'),st=gv('rpc_state'),img=gv('rpc_large_image');
  $('prevType').textContent=type; $('prevName').textContent=name;
  const de=$('prevDetails'),se=$('prevState');
  de.textContent=det;de.style.display=det?'block':'none';
  se.textContent=st;se.style.display=st?'block':'none';
  const pi=$('prevImg');
  pi.innerHTML=img?`<img src="${img}" onerror="this.parentElement.innerHTML='<i class=\\'fas fa-image\\'></i>'">`:'<i class="fas fa-image"></i>';
}

function toggleStreamUrl(){
  $('streamUrlField').style.display=gv('rpc_type')==='STREAMING'?'block':'none';
}

// ── Quest Functions ───────────────────────────────────────────────────────────
let questPollTimer = null;
let lastLogCount = 0;
let cachedQuests = [];

async function loadQuests(){
  const list=$('questList');
  list.innerHTML='<div class="quest-empty"><i class="fas fa-spinner fa-spin"></i> Loading quests…</div>';
  try {
    const d = await fetch('/api/quests').then(r=>r.json());
    if (!d.success) { list.innerHTML=`<div class="quest-empty" style="color:var(--red)">${d.error||'Failed to load'}</div>`; return; }
    cachedQuests = d.quests;
    renderQuestList(d.quests);
  } catch(e) {
    list.innerHTML=`<div class="quest-empty" style="color:var(--red)">Error: ${e.message}</div>`;
  }
}

function renderQuestList(quests){
  const list=$('questList');
  if(!quests||quests.length===0){
    list.innerHTML='<div class="quest-empty">No quests available right now</div>'; return;
  }
  list.innerHTML = quests.map(q=>{
    const taskBadge = q.type==='PLAY_ON_DESKTOP'
      ? `<span class="badge badge-play"><i class="fas fa-gamepad"></i> Play</span>`
      : `<span class="badge badge-video"><i class="fas fa-film"></i> Watch</span>`;
    const statusBadge = q.completed
      ? `<span class="badge badge-done"><i class="fas fa-check"></i> Done</span>`
      : q.expired ? `<span class="badge badge-exp"><i class="fas fa-clock"></i> Expired</span>` : '';
    const disabled = q.completed||q.expired;
    const icon = q.appId
      ? `<img src="https://cdn.discordapp.com/app-icons/${q.appId}/a_.png" onerror="this.parentElement.innerHTML='<i class=\\'fas fa-gamepad\\'></i>'">`
      : '<i class="fas fa-gamepad"></i>';
    return `<div class="quest-item${disabled?' completed':''}" id="qi-${q.id}">
      <div class="quest-icon">${icon}</div>
      <div class="quest-info">
        <div class="quest-name">${escHtml(q.name)}</div>
        <div class="quest-meta">${q.game?`<span><i class="fas fa-dice-d20"></i> ${escHtml(q.game)}</span>`:''}${taskBadge}${statusBadge}</div>
      </div>
      ${!disabled?`<button class="btn btn-ghost btn-sm" onclick="startQuest('${q.id}')"><i class="fas fa-play"></i> Start</button>`:''}
    </div>`;
  }).join('');
}

async function startAllQuests(){
  const d = await fetch('/api/quests/start',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({})}).then(r=>r.json());
  if(!d.success){toast(d.error||'Failed to start',false);return;}
  toast('Starting all quests one by one…',true);
  startQuestPoll();
}

async function startQuest(questId){
  const d = await fetch('/api/quests/start',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({questId})}).then(r=>r.json());
  if(!d.success){toast(d.error||'Failed to start',false);return;}
  const q = cachedQuests.find(x=>x.id===questId);
  toast(`Starting: ${q?.name||questId}`,true);
  startQuestPoll();
}

async function stopQuests(){
  await fetch('/api/quests/stop',{method:'POST'});
  toast('Stopped.',true);
}

async function clearQuestLogs(){
  await fetch('/api/quests/clear-logs',{method:'POST'});
  $('questLog').innerHTML='<span style="color:var(--text-muted)">Logs cleared.</span>';
  lastLogCount=0;
}

function startQuestPoll(){
  if(questPollTimer) return;
  questPollTimer = setInterval(pollQuestStatus, 1500);
  pollQuestStatus();
}

async function pollQuestStatus(){
  try {
    const d = await fetch('/api/quests/status').then(r=>r.json());
    // Update banner
    const banner=$('questBanner');
    const bannerText=$('questBannerText');
    if(d.isRunning){
      banner.classList.add('active');
      bannerText.textContent = d.currentQuest
        ? `Running: ${d.currentQuest.name} — Discord shows "Playing ${d.currentQuest.name}"`
        : 'Running quests…';
      $('startAllBtn').style.display='none';
      $('stopBtn').style.display='inline-flex';
      // Highlight running quest
      document.querySelectorAll('.quest-item').forEach(el=>el.classList.remove('running'));
      if(d.currentQuest){
        const el=$(`qi-${d.currentQuest.id}`);
        if(el) el.classList.add('running');
      }
    } else {
      banner.classList.remove('active');
      $('startAllBtn').style.display='inline-flex';
      $('stopBtn').style.display='none';
      document.querySelectorAll('.quest-item').forEach(el=>el.classList.remove('running'));
      if(questPollTimer){ clearInterval(questPollTimer); questPollTimer=null; }
    }
    // Append new logs
    if(d.logs && d.logs.length > lastLogCount){
      const logEl=$('questLog');
      const newLines = d.logs.slice(lastLogCount);
      lastLogCount = d.logs.length;
      if(lastLogCount===0) logEl.innerHTML='';
      newLines.forEach(line=>{
        const div=document.createElement('div');
        div.className='log-line'+(line.includes('COMPLETED')?' log-done':line.includes('Error')||line.includes('error')?' log-err':line.includes('Starting')||line.includes('Quest')?' log-info':'');
        div.textContent=line;
        logEl.appendChild(div);
      });
      logEl.scrollTop=logEl.scrollHeight;
    }
  } catch(e){}
}

function escHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function toast(msg,ok){
  const t=document.createElement('div');
  t.className='toast '+(ok?'tok':'terr');t.textContent=msg;
  document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
}

loadForm();
// Check if quests are already running on page load
pollQuestStatus();
</script>
</body>
</html>
